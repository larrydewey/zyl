; ============================================================================
; Standard Library Tests — Core Module (§20.1)
; TDD: Tests written BEFORE implementation
; ============================================================================

(test-suite "core"
  :category "math"
  :priority "essential"

  ; --- identity ---
  (test "identity returns its argument unchanged"
    :category "math"
    (assert-equal 42 (identity 42))
    (assert-equal 0 (identity 0))
    (assert-equal -7 (identity -7))
    (assert-equal 3.14 (identity 3.14)))

  ; --- const ---
  (test "const returns a function that always returns the given value"
    :category "math"
    (let ((c5 (const 5)))
      (assert-equal 5 (c5 1))
      (assert-equal 5 (c5 99))
      (assert-equal 5 (c5 "anything")))
    (let ((hello (const "hello")))
      (assert-equal "hello" (hello 0))))

  ; --- compose ---
  (test "compose(f, g) returns f(g(x))"
    :category "math"
    (let ((inc (fn (x) (+ x 1)))
          (sq  (fn (x) (* x x))))
      (let ((f (compose inc sq)))
        ; f(3) = inc(sq(3)) = inc(9) = 10
        (assert-equal 10 (f 3)))
      (let ((g (compose sq inc)))
        ; g(3) = sq(inc(3)) = sq(4) = 16
        (assert-equal 16 (g 3)))))

  ; --- when ---
  (test "when executes body only when condition is truthy"
    :category "control"
    (let ((result 0))
      (when true (def result 42))
      (assert-equal 42 result)
      (def result 0)
      (when false (def result 99))
      (assert-equal 0 result)))

  ; --- unless ---
  (test "unless executes body only when condition is falsy"
    :category "control"
    (let ((result 0))
      (unless true (def result 42))
      (assert-equal 0 result)
      (def result 0)
      (unless false (def result 42))
      (assert-equal 42 result)))

  ; --- max ---
  (test "max returns the larger of two values"
    :category "math"
    (assert-equal 5 (max 3 5))
    (assert-equal 5 (max 5 3))
    (assert-equal 5 (max 5 5))
    (assert-equal -1 (max -5 -1))
    (assert-equal 3.14 (max 2.71 3.14)))

  ; --- min ---
  (test "min returns the smaller of two values"
    :category "math"
    (assert-equal 3 (min 3 5))
    (assert-equal 3 (min 5 3))
    (assert-equal 5 (min 5 5))
    (assert-equal -5 (min -5 -1))
    (assert-equal 2.71 (min 2.71 3.14)))

  ; --- abs ---
  (test "abs returns absolute value"
    :category "math"
    (assert-equal 42 (abs 42))
    (assert-equal 42 (abs -42))
    (assert-equal 0 (abs 0))
    (assert-equal 3.14 (abs -3.14)))

  ; --- sum ---
  (test "sum returns the sum of a list"
    :category "math"
    (assert-equal 0 (sum '()))
    (assert-equal 5 (sum '(5)))
    (assert-equal 10 (sum '(1 2 3 4)))
    (assert-equal -1 (sum '(-1 -2 -3))))

  ; --- product ---
  (test "product returns the product of a list"
    :category "math"
    (assert-equal 1 (product '()))
    (assert-equal 6 (product '(1 2 3)))
    (assert-equal 24 (product '(1 2 3 4)))
    (assert-equal 0 (product '(0 5 10))))

  ; --- clamp ---
  (test "clamp restricts value to [lo, hi] range"
    :category "math"
    (assert-equal 5 (clamp 10 0 10))
    (assert-equal 0 (clamp -5 0 10))
    (assert-equal 10 (clamp 15 0 10))
    (assert-equal 5 (clamp 5 0 10)))

  ; --- factorial ---
  (test "factorial computes n!"
    :category "math"
    (assert-equal 1 (factorial 0))
    (assert-equal 1 (factorial 1))
    (assert-equal 120 (factorial 5))
    (assert-equal 720 (factorial 6)))

  ; --- sign ---
  (test "sign returns -1, 0, or 1 based on value"
    :category "math"
    (assert-equal 1 (sign 42))
    (assert-equal -1 (sign -42))
    (assert-equal 0 (sign 0)))

  ; --- modulo — positive remainder ---
  (test "modulo returns non-negative remainder"
    :category "math"
    (assert-equal 2 (modulo 7 3))
    (assert-equal 1 (modulo 7 3))
    (assert-equal 0 (modulo 6 3)))

  ; --- pow — integer exponentiation ---
  (test "pow computes base^exp for non-negative exp"
    :category "math"
    (assert-equal 1 (pow 2 0))
    (assert-equal 2 (pow 2 1))
    (assert-equal 8 (pow 2 3))
    (assert-equal 1024 (pow 2 10)))

  ; --- range — generate list from start to end ---
  (test "range generates a list of integers"
    :category "math"
    (assert-equal '(0 1 2 3 4) (range 0 5))
    (assert-equal '(2 3 4 5 6) (range 2 7)))

  ; --- reverse — reverse a list ---
  (test "reverse returns the list in reverse order"
    :category "math"
    (assert-equal '() (reverse '()))
    (assert-equal '(1) (reverse '(1)))
    (assert-equal '(3 2 1) (reverse '(1 2 3))))

  ; --- length — list length ---
  (test "length returns the number of elements"
    :category "math"
    (assert-equal 0 (length '()))
    (assert-equal 3 (length '(1 2 3)))
    (assert-equal 5 (length '(1 2 3 4 5))))

  ; --- nth — get element at index ---
  (test "nth returns the element at a given index"
    :category "math"
    (assert-equal 10 (nth '(10 20 30) 0))
    (assert-equal 20 (nth '(10 20 30) 1))
    (assert-equal 30 (nth '(10 20 30) 2)))

  ; --- first — get first element ---
  (test "first returns the first element of a list"
    :category "math"
    (assert-equal 10 (first '(10 20 30))))

  ; --- rest — get all but first element ---
  (test "rest returns all elements except the first"
    :category "math"
    (assert-equal '(20 30) (rest '(10 20 30))))

  ; --- append — concatenate two lists ---
  (test "append concatenates two lists"
    :category "math"
    (assert-equal '(1 2 3 4) (append '(1 2) '(3 4)))
    (assert-equal '(1 2) (append '() '(1 2)))
    (assert-equal '(3 4) (append '(3 4) '())))

  ; --- map — apply function to each element ---
  (test "map applies a function to each element"
    :category "math"
    (let ((double (fn (x) (* x 2))))
      (assert-equal '(2 4 6 8) (map double '(1 2 3 4)))))

  ; --- filter — keep elements where predicate is true ---
  (test "filter keeps elements matching predicate"
    :category "math"
    (let ((even? (fn (x) (== (modulo x 2) 0))))
      (assert-equal '(2 4 6) (filter even? '(1 2 3 4 5 6)))))

  ; --- fold-left — left fold / reduce ---
  (test "fold-left accumulates from the left"
    :category "math"
    (assert-equal 10 (fold-left + 0 '(1 2 3 4)))
    (assert-equal 24 (fold-left * 1 '(1 2 3 4))))

  ; --- all? — check if all elements satisfy predicate ---
  (test "all? returns true if all elements match"
    :category "math"
    (let ((positive? (fn (x) (> x 0))))
      (assert-true (all? positive? '(1 2 3)))
      (assert-false (all? positive? '(1 -2 3)))))

  ; --- any? — check if any element satisfies predicate ---
  (test "any? returns true if any element matches"
    :category "math"
    (let ((negative? (fn (x) (< x 0))))
      (assert-false (any? negative? '(1 2 3)))
      (assert-true (any? negative? '(1 -2 3)))))

  ; --- find — find first element matching predicate ---
  (test "find returns first matching element or unit"
    :category "math"
    (let ((even? (fn (x) (== (modulo x 2) 0))))
      (assert-equal 2 (find even? '(1 2 3)))
      (assert-equal (unit) (find even? '(1 3 5)))))

  ; --- zip — pair elements from two lists ---
  (test "zip pairs elements from two lists"
    :category "math"
    (assert-equal '((1 a) (2 b) (3 c)) (zip '(1 2 3) '(a b c))))

  ; --- curry — partial application ---
  (test "curry enables partial application"
    :category "math"
    (let ((add3 (fn (a b c) (+ a (+ b c)))))
      (let ((add5 (curry add3 5)))
        (let ((add5+2 (add5 2)))
          (assert-equal 7 (add5+2 0))))))

  ; --- negate — numeric negation ---
  (test "negate returns the negation"
    :category "math"
    (assert-equal -5 (negate 5))
    (assert-equal 5 (negate -5))
    (assert-equal 0 (negate 0)))

  ; --- square — x * x ---
  (test "square returns x squared"
    :category "math"
    (assert-equal 25 (square 5))
    (assert-equal 0 (square 0))
    (assert-equal 16 (square -4)))

  ; --- cube — x * x * x ---
  (test "cube returns x cubed"
    :category "math"
    (assert-equal 27 (cube 3))
    (assert-equal 0 (cube 0))
    (assert-equal -8 (cube -2)))

  ; --- even? / odd? ---
  (test "even? and odd? predicates work correctly"
    :category "math"
    (assert-true (even? 4))
    (assert-false (even? 3))
    (assert-false (odd? 4))
    (assert-true (odd? 3)))

  ; --- between — check if value is in range ---
  (test "between checks if value is strictly between lo and hi"
    :category "math"
    (assert-true (between 5 1 10))
    (assert-false (between 1 1 10))
    (assert-false (between 10 1 10)))

  ; --- lerp — linear interpolation ---
  (test "lerp interpolates between a and b by t"
    :category "math"
    (assert-equal 0 (lerp 0 10 0))
    (assert-equal 10 (lerp 0 10 1))
    (assert-equal 5 (lerp 0 10 0.5)))

)

; Run all tests
(run-tests :verbose true)
