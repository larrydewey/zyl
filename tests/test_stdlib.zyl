; ============================================================================
; Standard Library Test Suite — TDD for Lithp Stdlib
; Tests core and list operations using the testing framework
; ============================================================================

; --- Core function definitions (inline, no external deps) ---
(def identity (fn (x) x))
(def const-val (fn (val) (fn (_) val)))
(def compose-fn ((f) (fn (g) (fn (x) (f (g x))))))
(def when-fn ((cond) (fn (body) (if cond body (unit)))))
(def unless-fn ((cond) (fn (body) (if cond (unit) body))))
(def negate-fn ((x) (- x)))
(def square-fn ((x) (* x x)))
(def cube-fn ((x) (* x (* x x))))
(def max-fn ((a) (fn (b) (if (> a b) a b))))
(def min-fn ((a) (fn (b) (if (< a b) a b))))
(def abs-fn ((x) (if (< x 0) (- x) x)))
(def sign-fn ((x) (if (> x 0) 1 (if (< x 0) -1 0))))
(def modulo-fn ((a) (fn (b) (let (r (% a b)) (if (>= r 0) r (+ r b))))))
(def pow-fn ((base) (fn (exp) (if (== exp 0) 1 (* base (pow-fn base (- exp 1)))))))
(def factorial-fn ((n) (if (<= n 1) 1 (* n (factorial-fn (- n 1))))))
(def clamp-val ((val) (fn (lo) (fn (hi) (if (< val lo) lo (if (> val hi) hi val))))))
(def between-val ((val) (fn (lo) (fn (hi) (and (> val lo) (< val hi))))))
(def lerp-val ((a) (fn (b) (fn (t) (+ a (* (- b a) t))))))
(def even?-fn ((x) (== (modulo-fn x 2) 0)))
(def odd?-fn ((x) (not (even?-fn x))))

; --- List operations using builtins: first, rest, length, cons, append, nth, list ---
(def reverse-fn ((lst)
  (let (acc '())
    (let (rev-step (fn ((lst) (fn ((acc)
      (if (== lst '())
        acc
        (rev-step (rest lst) (cons (first lst) acc)))))))
      (rev-step lst acc)))))

(def append-fn ((a) (fn (b)
  (if (== a '())
    b
    (cons (first a) (append-fn (rest a) b))))))

(def nth-fn ((lst) (fn (i)
  (if (== i 0)
    (first lst)
    (nth-fn (rest lst) (- i 1))))))

(def map-fn ((f) (fn (lst)
  (if (== lst '())
    '()
    (cons (f (first lst)) (map-fn f (rest lst)))))))

(def filter-fn ((pred) (fn (lst)
  (if (== lst '())
    '()
    (if (pred (first lst))
      (cons (first lst) (filter-fn pred (rest lst)))
      (filter-fn pred (rest lst)))))))

(def fold-left-fn ((f) (fn (acc) (fn (lst)
  (if (== lst '())
    acc
    (fold-left-fn f (f acc (first lst)) (rest lst)))))))

(def all?-fn ((pred) (fn (lst)
  (if (== lst '())
    true
    (and (pred (first lst)) (all?-fn pred (rest lst)))))))

(def any?-fn ((pred) (fn (lst)
  (if (== lst '())
    false
    (or (pred (first lst)) (any?-fn pred (rest lst)))))))

(def find-fn ((pred) (fn (lst)
  (if (== lst '())
    (unit)
    (if (pred (first lst))
      (first lst)
      (find-fn pred (rest lst)))))))

(def zip-fn ((a) (fn (b)
  (if (or (== a '()) (== b '()))
    '()
    (cons (list (first a) (first b)) (zip-fn (rest a) (rest b)))))))

; ============================================================================
; TESTS
; ============================================================================

(test-suite "stdlib"
  :category "core"
  :priority "essential"

  ; --- identity ---
  (test "identity returns its argument"
    (assert-equal 42 (identity 42))
    (assert-equal 0 (identity 0))
    (assert-equal -7 (identity -7)))

  ; --- const ---
  (test "const returns a constant function"
    (def c5 (const-val 5))
    (assert-equal 5 (c5 1))
    (assert-equal 5 (c5 99))
    (def hello (const-val "hello"))
    (assert-equal "hello" (hello 0)))

  ; --- compose ---
  (test "compose(f, g) returns f(g(x))"
    (def inc (fn (x) (+ x 1)))
    (def sq (fn (x) (* x x)))
    (def f (compose-fn inc sq))
    (assert-equal 10 (f 3))
    (def g (compose-fn sq inc))
    (assert-equal 16 (g 3)))

  ; --- when/unless ---
  (test "when executes body when condition is truthy"
    (def result 0)
    (when-fn true (fn () (begin (def result 42))))
    (assert-equal 42 result)
    (def result 0)
    (when-fn false (fn () (begin (def result 99))))
    (assert-equal 0 result))

  (test "unless executes body when condition is falsy"
    (def result 0)
    (unless-fn true (fn () (begin (def result 42))))
    (assert-equal 0 result)
    (def result 0)
    (unless-fn false (fn () (begin (def result 42))))
    (assert-equal 42 result))

  ; --- negate ---
  (test "negate returns the negation"
    (assert-equal -5 (negate-fn 5))
    (assert-equal 5 (negate-fn -5))
    (assert-equal 0 (negate-fn 0)))

  ; --- square ---
  (test "square returns x squared"
    (assert-equal 25 (square-fn 5))
    (assert-equal 0 (square-fn 0))
    (assert-equal 16 (square-fn -4)))

  ; --- cube ---
  (test "cube returns x cubed"
    (assert-equal 27 (cube-fn 3))
    (assert-equal 0 (cube-fn 0))
    (assert-equal -8 (cube-fn -2)))

  ; --- max ---
  (test "max returns the larger value"
    (def m5 ((max-fn 3)))
    (assert-equal 5 (m5 5))
    (def m3 ((max-fn 5)))
    (assert-equal 5 (m3 3))
    (def m5b ((max-fn 5)))
    (assert-equal 5 (m5b 5)))

  ; --- min ---
  (test "min returns the smaller value"
    (def n3 ((min-fn 3)))
    (assert-equal 3 (n3 5))
    (def n3b ((min-fn 5)))
    (assert-equal 3 (n3b 3)))

  ; --- abs ---
  (test "abs returns absolute value"
    (assert-equal 42 (abs-fn 42))
    (assert-equal 42 (abs-fn -42))
    (assert-equal 0 (abs-fn 0)))

  ; --- sign ---
  (test "sign returns -1, 0, or 1"
    (assert-equal 1 (sign-fn 42))
    (assert-equal -1 (sign-fn -42))
    (assert-equal 0 (sign-fn 0)))

  ; --- modulo ---
  (test "modulo returns non-negative remainder"
    (assert-equal 1 (modulo-fn 7 3))
    (assert-equal 0 (modulo-fn 6 3)))

  ; --- pow ---
  (test "pow computes base^exp"
    (assert-equal 1 (pow-fn 2 0))
    (assert-equal 2 (pow-fn 2 1))
    (assert-equal 8 (pow-fn 2 3))
    (assert-equal 1024 (pow-fn 2 10)))

  ; --- factorial ---
  (test "factorial computes n!"
    (assert-equal 1 (factorial-fn 0))
    (assert-equal 1 (factorial-fn 1))
    (assert-equal 120 (factorial-fn 5))
    (assert-equal 720 (factorial-fn 6)))

  ; --- clamp ---
  (test "clamp restricts value to range"
    (def cl10 ((clamp-val 10)))
    (assert-equal 5 ((cl10 0) 10))
    (def cl-5 ((clamp-val -5)))
    (assert-equal 0 ((cl-5 0) 10))
    (def cl15 ((clamp-val 15)))
    (assert-equal 10 ((cl15 0) 10)))

  ; --- between ---
  (test "between checks strict range"
    (def bt5 ((between-val 5)))
    (assert-true ((bt5 1) 10))
    (assert-false (((between-val 1) 1) 10))
    (assert-false (((between-val 10) 1) 10)))

  ; --- lerp ---
  (test "lerp interpolates between values"
    (def lr0 ((lerp-val 0)))
    (assert-equal 0 ((lr0 10) 0))
    (assert-equal 10 ((lr0 10) 1))
    (assert-equal 5 ((lr0 10) 0.5)))

  ; --- even?/odd? ---
  (test "even? and odd? work correctly"
    (assert-true (even?-fn 4))
    (assert-false (even?-fn 3))
    (assert-false (odd?-fn 4))
    (assert-true (odd?-fn 3)))

  ; --- List operations ---
  (test "first returns first element"
    (assert-equal 10 (first '(10 20 30))))

  (test "rest returns all but first"
    (assert-equal '(20 30) (rest '(10 20 30))))

  (test "length returns element count"
    (assert-equal 0 (length '()))
    (assert-equal 3 (length '(1 2 3)))
    (assert-equal 5 (length '(1 2 3 4 5))))

  (test "cons prepends element"
    (assert-equal '(0 1 2) (cons 0 '(1 2))))

  (test "append concatenates lists"
    (assert-equal '(1 2 3 4) (append-fn '(1 2) '(3 4)))
    (assert-equal '(1 2) (append-fn '() '(1 2)))
    (assert-equal '(3 4) (append-fn '(3 4) '())))

  (test "nth gets element at index"
    (assert-equal 10 (nth-fn '(10 20 30) 0))
    (assert-equal 20 (nth-fn '(10 20 30) 1))
    (assert-equal 30 (nth-fn '(10 20 30) 2)))

  (test "reverse reverses a list"
    (assert-equal '() (reverse-fn '()))
    (assert-equal '(1) (reverse-fn '(1)))
    (assert-equal '(3 2 1) (reverse-fn '(1 2 3))))

  (test "map applies function to each element"
    (def double (fn (x) (* x 2)))
    (assert-equal '(2 4 6 8) (map-fn double '(1 2 3 4))))

  (test "filter keeps matching elements"
    (def is-even (fn (x) (== (modulo-fn x 2) 0)))
    (assert-equal '(2 4 6) (filter-fn is-even '(1 2 3 4 5 6))))

  (test "fold-left accumulates from left"
    (assert-equal 10 (fold-left-fn + 0 '(1 2 3 4)))
    (assert-equal 24 (fold-left-fn * 1 '(1 2 3 4))))

  (test "all? checks all elements"
    (def is-positive (fn (x) (> x 0)))
    (assert-true (all?-fn is-positive '(1 2 3)))
    (assert-false (all?-fn is-positive '(1 -2 3))))

  (test "any? checks any element"
    (def is-negative (fn (x) (< x 0)))
    (assert-false (any?-fn is-negative '(1 2 3)))
    (assert-true (any?-fn is-negative '(1 -2 3))))

  (test "find returns first matching element"
    (def is-even (fn (x) (== (modulo-fn x 2) 0)))
    (assert-equal 2 (find-fn is-even '(1 2 3)))
    (assert-equal (unit) (find-fn is-even '(1 3 5))))

  (test "zip pairs elements"
    (assert-equal '((1 a) (2 b) (3 c)) (zip-fn '(1 2 3) '(a b c))))

)

; Run all tests
(run-tests :verbose true)
