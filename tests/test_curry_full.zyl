(def inc (fn (x) (+ x 1)))
(def double (fn (x) (* x 2)))

; SECTION 1: Basic curried lambda syntax ((x) body) - Spec S7.2
((fn (x) x) 42)
(((fn (a) (fn (b) (+ a b))) 3) 4)
(((fn (a) (fn (b) (fn (c) (+ a (+ b c))))) 10) 20) 5

; SECTION 2: Curried function via def - Spec S7.2 "Usage contexts"
(def add-one ((x) (+ x 1)))
(add-one 41)
(def add-two ((a) (b) (+ a b)))
((add-two 7) 8)
(def add-three ((a) (b) (c) (+ a (+ b c))))
(((add-three 10) 20) 5)

; SECTION 3: Partial application of curried functions - Spec S7.2
(def add-seven (add-two 7))
(add-seven 8)
(defn add-three-def ((a) (b) (c) (+ a (+ b c))))
(def add-thirty ((b) (c) (+ 10 (+ b c))))
((add-thirty 20) 5)

; SECTION 4: Curried fn in let - Spec S7.2 "Usage contexts"
(let ((square ((x) (* x x))))
  (square 6))
(let ((triple ((y) (* y 3)))
      (add-a ((z) (+ z 100))))
  (+ (triple 5) (add-a 1)))

; SECTION 5: Curried fn as argument - Spec S7.2 "Usage contexts"
(((fn (f) (fn (x) (f x))) ((a) (+ a 10))) 32)
(def compose ((f) (g) (fn (x) (f (g x)))))
(((compose ((y) (* y 2))) ((z) (+ z 5))) 10)

; SECTION 6: Curried closure captures environment - Spec S7.3, S7.6
(def make-adder ((n) (fn (x) (+ n x))))
((make-adder 10) 32)
(def make-multiplier ((m) (fn (y) (* m y))))
((make-multiplier 5) 8)
(def outer-capture ((base)
  (let ((offset ((x) (+ x base))))
    (fn (v) (offset v)))))
((outer-capture 100) 23)

; SECTION 7: Recursive functions with curried syntax - Spec S7.5
(defn fact ((n) (if (<= n 1) 1 (* n (fact (- n 1))))))
(fact 6)
(defn fib ((n) (if (< n 2) n (+ (fib (- n 1)) (fib (- n 2))))))
(fib 10)

; SECTION 8: Zero-param closure via explicit fn - Spec S7.2
((fn () 42))
((fn () (* 6 9)))
(def constant-fn (fn () "hello"))
(constant-fn)

; SECTION 9: Curried with all arithmetic ops - Spec S21.1
(((fn (a) (fn (b) (- a b))) 30) 8)
(((fn (a) (fn (b) (/ a b))) 100) 5)
(((fn (a) (fn (b) (% a b))) 17) 5)

; SECTION 10: Curried with comparison ops - Spec S21.2
(((fn (a) (fn (b) (if (> a b) "gt" "le"))) 10) 5)
(((fn (a) (fn (b) (if (< a b) "lt" "ge"))) 3) 7)

; SECTION 11: Curried with boolean ops - Spec S21.3
(((fn (f) (fn (x) (not x))) true))
(((fn (a) (fn (b) (and a b))) true false))
(((fn (a) (fn (b) (or a b))) false true))

; SECTION 14: Deeply nested currying - Spec S7.2 (using def to avoid direct nesting issues)
(defn add-four ((w) (x) (y) (z) (+ w (+ x (+ y z)))))
((((add-four 1) 2) 3) 4)

; SECTION 15: Curried function returning unit - Spec S7.2
((fn (_) 0))

; SECTION 16: Curried with floats - Spec S20.2
(((fn (a) (fn (b) (+ a b))) 1.5) 2.5)
(((fn (a) (fn (b) (* a b))) 3.0) 4.0)

; SECTION 17: Partial application chaining - Spec S7.2
(defn add-three-chain ((a) (b) (c) (+ a (+ b c))))
(def step1 (add-three-chain 1))
(def step2 (step1 2))
(step2 3)
(defn multiply-three ((a) (b) (c) (* a (* b c))))
(def double-all (multiply-three 2))
(def quadruple (double-all 2))
(quadruple 1)

; SECTION 18: Curried function returning another curried function - Spec S7.2
(defn factory ((x) (fn (y) (+ x y))))
((factory 10) 5)
(defn outer-factory ((a) 
  (def inner-factory ((b) (* a b)))
  inner-factory))
((outer-factory 3) 8)

; SECTION 19: Curried with if/else - Spec S7.1
(((fn (n) (if (> n 0) "positive" "non-positive")) 42))
(((fn (n) (if (== n 0) "zero" (if (> n 0) "pos" "neg"))) 0))

; SECTION 20: Curried with try/catch - Spec S7.1
(try ((fn (x) x) 42)
  (catch e 0))

; SECTION 21: Curried with match - Spec S8.3
(((fn (n) (match n 
  (0 "zero")
  (1 "one")
  (_ "other"))) 1))

; SECTION 22: Curried with cond - Spec S12.7
(((fn (n) (cond 
  ((< n 0) "small")
  ((> n 100) "big")
  (else "medium"))) 200))

; SECTION 23: Curried with assert - Spec S7.1
(assert (> ((fn (x) x) 5) 0) "test")

; SECTION 24: Curried with defn - Spec S7.2
(defn square ((x) (* x x)))
(square 12)
(defn power ((base) (fn (exp) 
  (if (== exp 0) 1 (* base (power base (- exp 1)))))))
(power 2 3)

; SECTION 25: Curried with fn - Spec S7.1
(def add-curried ((a) (b) (+ a b)))
(def add-explicit (fn ((a) (b) (+ a b))))
((add-curried 7) 8)
((add-explicit 7) 8)

; SECTION 26: Edge cases - Spec S7.2
(((fn (a) (fn (b) (+ a b))) 0) 0)
