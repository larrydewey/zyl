; ============================================================================
; Isolation Tests — find what's breaking in test_stdlib.zyl
; ============================================================================

; --- Test 1: Basic let with single binding (no parens around name) ---
(def t1-result 0)
(let (t1-result 42)
  (print t1-result))

; --- Test 2: Let with quoted empty list ---
(let (my-list '())
  (print my-list))

; --- Test 3: Nested let with single binding syntax ---
(let (acc '())
  (let (rev-step "hello")
    (print rev-step)))

; --- Test 4: Curried lambda in let ---
(let (f (fn ((x) (+ x 1))))
  (print (f 5)))

; --- Test 5: Recursive function via let ---
(let (fact (fn ((n)
  (if (<= n 1)
    1
    (* n (fact (- n 1)))))))
  (print (fact 5)))

; --- Test 6: Reverse with accumulator pattern ---
(def reverse-test ((lst)
  (let (acc '())
    (let (rev-step (fn ((lst) (fn ((acc)
      (if (== lst '())
        acc
        (rev-step (rest lst) (cons (first lst) acc)))))))
      (rev-step lst acc)))))

; --- Test 7: Simple list operations ---
(print (first '(10 20 30)))
(print (rest '(10 20 30)))
(print (length '(1 2 3)))
(print (cons 0 '(1 2)))

; --- Test 8: Append ---
(def my-append ((a) (fn (b)
  (if (== a '())
    b
    (cons (first a) (my-append (rest a) b))))))
(print (my-append '(1 2) '(3 4)))

; --- Test 9: Map ---
(def my-map ((f) (fn (lst)
  (if (== lst '())
    '()
    (cons (f (first lst)) (my-map f (rest lst)))))))
(print (my-map (fn (x) (* x 2)) '(1 2 3 4)))

; --- Test 10: Filter ---
(def my-filter ((pred) (fn (lst)
  (if (== lst '())
    '()
    (if (pred (first lst))
      (cons (first lst) (my-filter pred (rest lst)))
      (my-filter pred (rest lst)))))))
(print (my-filter (fn (x) (== (% x 2) 0)) '(1 2 3 4 5 6)))

; --- Test 11: Fold-left ---
(def my-fold ((f) (fn (acc) (fn (lst)
  (if (== lst '())
    acc
    (my-fold f (f acc (first lst)) (rest lst)))))))
(print (my-fold + 0 '(1 2 3 4)))

; --- Test 12: Zip ---
(def my-zip ((a) (fn (b)
  (if (or (== a '()) (== b '()))
    '()
    (cons (list (first a) (first b)) (my-zip (rest a) (rest b)))))))
(print (my-zip '(1 2 3) '(a b c)))

; --- Test 13: Modulo with let binding in parens ---
(def my-mod ((a) (fn (b)
  (let ((r (% a b)))
    (if (>= r 0) r (+ r b))))))
(print (my-mod 7 3))

; --- Test 14: Pow recursive ---
(def my-pow ((base) (fn (exp)
  (if (== exp 0)
    1
    (* base (my-pow base (- exp 1)))))))
(print (my-pow 2 10))

; --- Test 15: Factorial recursive ---
(def my-factorial ((n)
  (if (<= n 1)
    1
    (* n (my-factorial (- n 1))))))
(print (my-factorial 6))
